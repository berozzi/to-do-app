<Window x:Class="ToDoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ToDoApp"
        mc:Ignorable="d"
        Title="To-do app" Height="450" Width="800">
    <Grid>
        <Grid Margin="0,0,400,0" x:Name="TaskDataGrid">
            <Label Content="Dodaj nowe zadanie" HorizontalAlignment="Center" Margin="29,24,0,0" VerticalAlignment="Top" FontSize="36"/>
            <TextBox x:Name="TaskName" HorizontalAlignment="Left" Margin="146,95,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="216" Height="22"/>
            <Label Content="Nazwa:" HorizontalAlignment="Left" Margin="29,87,0,0" VerticalAlignment="Top" Height="30"/>
            <Label Content="Opis:" HorizontalAlignment="Left" Margin="29,117,0,0" VerticalAlignment="Top" Height="30"/>
            <TextBox x:Name="TaskDescription" HorizontalAlignment="Left" Margin="146,125,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="216" Height="22"/>
            <Label Content="Data wykonania:" HorizontalAlignment="Left" Margin="29,155,0,0" VerticalAlignment="Top" Height="30"/>
            <DatePicker x:Name="TaskDate" HorizontalAlignment="Left" Margin="146,163,0,0" VerticalAlignment="Top" Width="216" Height="22"/>
            <Label Content="Priorytet:" HorizontalAlignment="Left" Margin="29,190,0,0" VerticalAlignment="Top" Height="30"/>
            <ComboBox x:Name="TaskPriority" HorizontalAlignment="Left" Margin="146,198,0,0" VerticalAlignment="Top" Width="216" Height="22">
                <ComboBoxItem Content="Niski"/>
                <ComboBoxItem Content="Średni"/>
                <ComboBoxItem Content="Wysoki"/>
            </ComboBox>
            <Button x:Name="AddTaskButton" Content="Dodaj zadanie" HorizontalAlignment="Left" Margin="146,225,0,0" VerticalAlignment="Top" Width="216" Height="22" Command="{Binding AddCommand}" />
        </Grid>
        <Grid x:Name="TaskListGrid" Margin="400,0,0,0">
            <Label Content="Lista zadań" HorizontalAlignment="Center" Margin="29,24,0,0" VerticalAlignment="Top" FontSize="36"/>
            <Grid x:Name="TaskList">
                <ListBox ItemsSource="{Binding Items}" Margin="0,93,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- template implementation -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Priority}" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding DueDate, StringFormat=d}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</Window>
