<Window x:Class="ToDoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ToDoApp"
        mc:Ignorable="d"
        Title="To-do app - zadania tygodniowe" Height="450" Width="800">
    <Grid>
        <Grid Margin="0,0,400,0" x:Name="TaskDataGrid">
            <Label Content="Dodaj nowe zadanie" HorizontalAlignment="Center" Margin="29,24,0,0" VerticalAlignment="Top" FontSize="36"/>
            <TextBox x:Name="TaskName" Text="{Binding TaskName}" HorizontalAlignment="Left" Margin="146,95,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="216" Height="22"/>
            <Label Content="Nazwa:" HorizontalAlignment="Left" Margin="29,87,0,0" VerticalAlignment="Top" Height="30"/>
            <Label Content="Opis:" HorizontalAlignment="Left" Margin="29,117,0,0" VerticalAlignment="Top" Height="30"/>
            <TextBox x:Name="TaskDescription" Text="{Binding TaskDescription}" HorizontalAlignment="Left" Margin="146,125,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="216" Height="22"/>
            <Label Content="Priorytet:" HorizontalAlignment="Left" Margin="29,147,0,0" VerticalAlignment="Top" Height="30"/>
            <ComboBox x:Name="TaskPriority" Text="{Binding Priority}" HorizontalAlignment="Left" Margin="146,162,0,0" VerticalAlignment="Top" Width="216" Height="22">
                <ComboBoxItem Content="Niski"/>
                <ComboBoxItem Content="Średni"/>
                <ComboBoxItem Content="Wysoki"/>
            </ComboBox>
            <Button x:Name="AddTaskButton" Content="Dodaj zadanie" HorizontalAlignment="Left" Margin="146,195,0,0" VerticalAlignment="Top" Width="216" Height="22" Command="{Binding AddCommand}" />
            <Button Content="Eksportuj" HorizontalAlignment="Left" Margin="146,396,0,0" VerticalAlignment="Top" Width="235"/>
        </Grid>
        <Grid x:Name="TaskListGrid" Margin="400,0,0,0">
            <Label Content="Lista zadań" HorizontalAlignment="Center" Margin="29,24,0,0" VerticalAlignment="Top" FontSize="36"/>
            <Grid x:Name="TaskList">
                <ListBox ItemsSource="{Binding Items}" Margin="0,93,0,0"
         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.15"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Nazwa zadania -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding TaskName}"
                               FontWeight="Bold"
                               FontSize="16"
                               Foreground="#222222"/>

                                    <!-- Priorytet jako "badge" -->
                                    <Border Grid.Row="0" Grid.Column="1"
                            Background="#4C8BF5"
                            CornerRadius="10"
                            Padding="8,2"
                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Priority}"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                                    </Border>

                                    <!-- Opis -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding TaskDescription}"
                               Foreground="#666666"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</Window>
